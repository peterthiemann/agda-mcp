{
  "name": "agda-mcp",
  "version": "0.2.0",
  "description": "A non-mutating MCP server for Agda's interaction protocol",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agda-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs dist .test-dist coverage",
    "clean:build": "node scripts/clean.mjs dist",
    "clean:test": "node scripts/clean.mjs .test-dist",
    "build": "npm run clean:build && tsc -p tsconfig.build.json && node scripts/make-executable.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test:compile": "npm run clean:test && tsc -p tsconfig.test.json",
    "test": "npm run test:compile && node scripts/run-tests.mjs unit",
    "test:fuzz": "npm run test:compile && node scripts/run-tests.mjs fuzz",
    "test:integration": "npm run test:compile && node scripts/run-tests.mjs integration",
    "test:package": "node scripts/test-packed-install.mjs",
    "test:all": "npm run test:compile && node scripts/run-tests.mjs",
    "start": "node dist/index.js",
    "smoke": "node dist/index.js --help",
    "prepack": "npm run test:all && npm run build && npm run smoke"
  },
  "keywords": [
    "agda",
    "mcp",
    "model-context-protocol",
    "theorem-proving"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterthiemann/agda-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/peterthiemann/agda-mcp/issues"
  },
  "homepage": "https://github.com/peterthiemann/agda-mcp#readme",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^22.20.1",
    "fast-check": "4.9.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  }
}
